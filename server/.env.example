# ─── Database (MongoDB Atlas) ───────────────────────────
# Use MONGODB_URI or MONGO_URI — both are supported
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster0.mongodb.net/?retryWrites=true&w=majority
DB_NAME=betteresume

# ─── Auth ─────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-string-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ─── Groq AI ──────────────────────────────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Upload ───────────────────────────────────────────
MAX_FILE_SIZE_MB=10

# ─── Deployment ───────────────────────────────────────
# Render injects PORT automatically — do not set manually on Render
PORT=8000
# Set this to your Vercel frontend URL after deploying
FRONTEND_URL=https://your-app.vercel.app
